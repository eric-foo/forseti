                      value += "0";
                  }
              }
              break;
          case 'amount_with_comma_separator':
          case 'amount_no_decimals_with_comma_separator':
              value = formatWithDelimiters(cents, currencyDecimal, '.', ',');
              if (__roundTo != null && value != 0 && value.toString().indexOf(",") !== -1) {
                  value = value.substr(0, (value.toString().indexOf(",") + 1)) + __roundTo;
                  if (__currentCurrency == "KWD" || __currentCurrency == "BHD" || __currentCurrency == "JOD" || __currentCurrency == "OMR") {
                      value += "0";
                  }
              }
              break;
      }
      if (!isNaN(cents)) {
