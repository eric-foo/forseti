{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$(git rev-parse --show-toplevel)/.codex/hooks/forseti_guard_codex_adapter.py\"",
            "commandWindows": "python -c \"import pathlib, runpy; cwd = pathlib.Path.cwd(); root = next((p for p in (cwd, *cwd.parents) if (p / '.codex/hooks/forseti_guard_codex_adapter.py').is_file()), None); assert root is not None, 'Forseti Codex guard adapter not found'; runpy.run_path(str(root / '.codex/hooks/forseti_guard_codex_adapter.py'), run_name='__main__')\"",
            "timeout": 10,
            "statusMessage": "Checking Forseti protected action policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$(git rev-parse --show-toplevel)/.agents/hooks/check_repo_map_freshness.py\" --hook",
            "commandWindows": "python \"$(git rev-parse --show-toplevel)/.agents/hooks/check_repo_map_freshness.py\" --hook",
            "timeout": 10,
            "statusMessage": "Checking Forseti repo-map commit policy"
          },
          {
            "type": "command",
            "command": "python \"$(git rev-parse --show-toplevel)/.agents/hooks/check_search_surface_google_route.py\" --hook",
            "commandWindows": "python \"$(git rev-parse --show-toplevel)/.agents/hooks/check_search_surface_google_route.py\" --hook",
            "timeout": 10,
            "statusMessage": "Checking Forseti Google search-surface route policy"
          }
        ]
      }
    ]
  }
}
