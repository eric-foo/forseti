<style>
  /* Define styles for dropdown menus */
  /* Define styles for dropdown menus */
  .dropdown-menu {
    display: none; /* Set to none by default */
    position: absolute;
    background-color: #fff;
    border: 1px solid #ccc;
    z-index: 1;
  }

  /* Styles for dropdown links */
  .dropdown-menu a {
    display: block;
    padding: 10px;
    text-decoration: none;
    color: #333;
  }

  /* Add more styles as needed */

  /* Style for when the dropdown is open */
  .dropdown-open {
    display: block; /* Display the dropdown when this class is applied */
  }

  .navlinks {
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }
  .navlinks .nav-link.dropdown-toggle {
    /*padding-left: 0!important;*/
  }
  .mobile-nav .dropdown-toggle::after {
    /*margin-left: 0rem !important;*/
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const dropdowns = document.querySelectorAll('.dropdown');
    const mobileNavOverlay = document.querySelector('.mobile-nav__overlay');
    const mobileNav = document.querySelector('.mobile-nav');

    function toggleDropdown(link, menu) {
      link.setAttribute('aria-expanded', link.getAttribute('aria-expanded') === 'true' ? 'false' : 'true');
      menu.classList.toggle('dropdown-open');
    }

    function closeDropdown(link, menu) {
      link.setAttribute('aria-expanded', 'false');
      menu.classList.remove('dropdown-open');
    }

    dropdowns.forEach(function (dropdown) {
      const link = dropdown.querySelector('a.dropdown-toggle');
      const menu = dropdown.querySelector('.dropdown-menu');

      if (link && menu) {
        link.addEventListener('click', function (event) {
          event.preventDefault();
          toggleDropdown(link, menu);
        });

        document.addEventListener('click', function (event) {
          if (
            !link.contains(event.target) &&
            !menu.contains(event.target) &&
            menu.classList.contains('dropdown-open')
          ) {
            closeDropdown(link, menu);
          }
        });

        const subMenuLinks = menu.querySelectorAll('.nav-link');
        subMenuLinks.forEach(function (subMenuLink) {
          subMenuLink.addEventListener('click', function (event) {
            event.preventDefault();
            closeDropdown(link, menu);
            mobileNavOverlay.style.display = 'none';
            mobileNav.classList.remove('show');
            const targetURL = subMenuLink.getAttribute('href');
            console.log('targetURL', targetURL);
            window.location.href = targetURL;
          });
        });
      }
    });

    function toggleMobileNav() {
      mobileNav.classList.toggle('show');
      mobileNavOverlay.style.display = mobileNav.classList.contains('show') ? 'block' : 'none';
    }

    document.querySelector('.navbar-toggler-mobile-nav').addEventListener('click', function (e) {
      e.preventDefault();
      toggleMobileNav();
    });

    document.querySelector('.mobile-sidebar__toggler').addEventListener('click', function (e) {
      e.preventDefault();
      toggleMobileNav();
    });
  });
</script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const navShopByConcern1 = document.getElementById('navShopByConcern1');
    const navShopByConcern = document.getElementById('navShopByConcern');
    const navShopByStep1 = document.getElementById('navShopByStep1');
    const navShopByStep = document.getElementById('navShopByStep');

    navShopByConcern.addEventListener('click', function (event) {
      if (navShopByConcern.getAttribute('aria-expanded') === 'false') {
        navShopByConcern.innerText = 'Shop by Concern';
        navShopByConcern1.style.display = 'none';
        navShopByStep.innerText = '';
        navShopByStep1.style.display = '';
      } else {
        navShopByConcern.innerText = '';
        navShopByConcern1.style.display = '';
        navShopByStep.innerText = 'Shop by Step';
        navShopByStep1.style.display = 'none';
      }
    });

    navShopByStep.addEventListener('click', function (event) {
      if (navShopByStep.getAttribute('aria-expanded') === 'false') {
        navShopByStep.innerText = 'Shop by Step';
        navShopByStep1.style.display = 'none';
        navShopByConcern.innerText = '';
        navShopByConcern1.style.display = '';
      } else {
        navShopByStep.innerText = '';
        navShopByStep1.style.display = '';
        navShopByConcern.innerText = 'Shop by Concern';
        navShopByConcern1.style.display = 'none';
      }
    });
  });
</script>

