<script>
document.addEventListener("DOMContentLoaded", function () {
  function handleUrlChange() {
    const pageUrl = window.location.href;

    if (pageUrl.includes("pages/shop-by-concern#")) {
      const tabLinks = document.querySelectorAll("#tabs_Collection_list li a");
      const activeTabs = document.querySelectorAll(".tab-pane.active");

      tabLinks.forEach((tabLink) => {
        tabLink.classList.remove("active");
        tabLink.setAttribute("aria-selected", "false");
      });

      activeTabs.forEach((tab) => {
        tab.classList.remove("active");
      });

      const fragment = pageUrl.substring(pageUrl.lastIndexOf("#") + 1);
console.log('fragment - '+fragment)

      const myArray = fragment.split("#");
      const myArray1 = myArray[0].split("?");
      
      const tabLinkToActivate = document.querySelector(`#${myArray1[0]}`);
      // tabLinkToActivate.click();
      const tabToActivate = document.getElementById(myArray1[0]+"-tab");
      console.log("tabToActivate",tabToActivate)
     
      if (tabLinkToActivate && tabToActivate) {
        tabLinkToActivate.classList.add("active");
        tabLinkToActivate.setAttribute("aria-selected", "true");
        tabToActivate.classList.add("active");
        
        if (tabLinkToActivate && window.innerWidth < 992) {
          tabLinkToActivate.scrollIntoView(true);
        }

      }
    }
  }

  handleUrlChange();

  window.addEventListener("popstate", handleUrlChange);
});
</script>
