        <div id="shopify-section-new-announcement-bar" class="shopify-section new announcement">
<style>
  .active-minds-announcement-bar .announcement-bgimg {
    background-image: url(//web.archive.org/web/20240625041836im_/https://www.cocokind.com/cdn/shop/files/BannerBackground_d806cee2-ffbb-4231-8d40-eb5040a92630.png?v=1714399457);
    background-size:cover;
    background-repeat:no-repeat;
    width:100%;
  }
  .active-minds-announcement-bar {
  display: none;
}
.active-minds-announcement-bar.is-visible {
  display: flex; /* or your preferred display property */
}

  @media (max-width:768px) {
    .active-minds-announcement-bar .announcement-bgimg {
    background-image: url(//web.archive.org/web/20240625041836im_/https://www.cocokind.com/cdn/shop/files/Mobile_Banner_Background_c92432b5-03ce-45f8-8c7f-490b431fb3e2.png?v=1714399459);
  }
  }
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  var sectionElement = document.querySelector(".active-minds-announcement-bar");

  function removeSection() {
    // Retrieve the value from localStorage and compare it as a string
    var showSection = localStorage.getItem("showSection");
    if (showSection === 'false') {
      sectionElement.style.display = "none";
    } else {
      sectionElement.style.display = "flex";
    }
  }
  removeSection();

  document
    .getElementById("close-bfcm-btn")
    .addEventListener("click", function () {
      showSection = false;
      sectionElement.style.display = "none";
      // Set the value in localStorage as a string
      localStorage.setItem("showSection", 'false');
    });
});
  
</script>


</div>
      
      
        <section id="shopify-section-expandable-announcement-bar" class="shopify-section">








<style>
  body.no-scroll {
    height: 100%;
    position: fixed !important;
    overflow: hidden;
    width: 100%;
  }
  .expandable-announcement-bar {
    position: relative;
    height: 25px;
    display: flex;
    background: #282828;
    background-size: 400vw 400vw;
    animation: gradient 6s ease infinite alternate;
  }
  .slide {
    visibility: hidden;
    opacity: 0;
    transition: all 500ms ease-in;
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    width: 100%;   
  }
  .slide p {
    color: #f7f4ec;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: -.01em;
    line-height: 1.25;    
  }
  .title_mobile {
    display: none;
  }
  .title_desktop {
    display: inline;
  }
  @media only screen and (max-width: 600px){
	.title_mobile {
      display: inline;
    }
    .title_desktop {
      display: none;
    }
  }
  
  .dropdown-enabled .slide p {
    cursor: pointer;
  }
  .slide svg {
    margin-left: 10px;
    fill: #f7f4ec;
  }
  .slide.active {
    visibility: visible;
    opacity: 1;
  }

  .drawer-top.is-collapsed .drawer-top__body {
    transform: translateY(-100%);
    transition: transform .3s cubic-bezier(.81,.005,.59,.98);
  }
   
  .drawer-top__body {
    background: #282828;
    background-size: 400vw 400vw;
    animation: gradient 6s ease infinite alternate;
    display: none;
    height: 100vh;
    left: 0;
    overflow: auto;
    position: absolute;
    top: 0;
    transform: translateY(-100%);
    transition: transform .4s cubic-bezier(.81,.005,.59,.98);
    width: 100%;
    z-index: 1111;
  }  
  .expandable-announcement-bar.is-animating .drawer-top__body {
    display: block;
  }
  .expandable-announcement-bar.is-expanded .drawer-top__body {
    display: block;
    transform: none;
  }
  .announcement-column__title {
    color: #f7f4ec;
  }
  .announcement-column__description {
    color: #f7f4ec;
  }
  .announcement-column__button {
    color: #f7f4ec;
  }
   
  @media only screen and (min-width: 768px) {
    .drawer-top__body-inner {
      overflow: hidden;
    }
  }  
  .drawer-top__body-inner {
    align-items: center;
    display: flex;
    height: 100%;
    position: relative;
    width: 100%;
    min-height: 100%;
  }  
  .drawer-top__body-content {
    height: auto;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity .6s cubic-bezier(.38,.41,.27,1),transform .6s cubic-bezier(.38,.41,.27,1);
    width: 100%;
    z-index: 1;
  }
  .drawer-top.is-expanded .drawer-top__body-content {
    opacity: 1;
    transform: none;
    transition-delay: .4s;
  }
  .drawer-top.is-expanded .drawer-top__close {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;    
  }
  .drawer-top__close {
    opacity: 0;
    pointer-events: none;
    transition: opacity .3s cubic-bezier(.395,0,.135,1);
    visibility: hidden;
    z-index: 9999;
  }
  .drawer-top__close .modal__close {
    overflow: hidden;
    position: absolute;
  }
  
  .modal-close {
    pointer-events: auto;
    position: fixed;
    right: 10px;
    top: 10px;
    z-index: 11;
  }
  .modal-close button {
    align-items: center;
    border-radius: 50px;
    display: inline-block;
    height: 100%;
    justify-content: center;
    min-width: 50px;
    position: relative;
    text-decoration: none;
    transition: transform .2s cubic-bezier(.235,0,.05,.95);
    background: transparent;
    outline: none;
    border: none;
  }

  .announcement__column p {
    margin: 10px 0px;
  }
  .announcement-bar p {
    font-weight: 400;
    font-size: 14px;
    line-height: 17px;
    color: #000000;
    letter-spacing: 0;
}
  .announcement-column__title {
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -.01em;
    line-height: 1.25;
  }
  .announcement-column__description {
    margin: 10px 0;
    font-size: 14px;
    line-height: 20px;
  }
  .announcement-column__button {
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -.01em;
    line-height: 1.25;
    text-decoration: underline;
  }

  /* Gradient Animation */
  @keyframes gradient {
    0% {
        background-color: 0% 00%;
    }
    100% {
        background-position: 100% 100%;
    }
  }
</style>


