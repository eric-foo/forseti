polyline points="12 5 19 12 12 19"></polyline></svg></span></div></div></div></button></div></div></div><button data-rid="26ba4c3a-b8e8-4d94-9c3a-68e7a383adfe" class="text r-10gxwma alchemy-rte"><div data-rid="54e077bd-729b-4805-af73-dd73adb33e99" class="r-9g4rco alchemy-rte"><span style="width:100%"><p>Learn More</p></span></div></button></div></div></div><div data-rid="86b52c63-e1c5-4445-83ed-f2e25cec3f8e" style="--replo-library-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-d607104b-b021-4f93-9724-53e6df016092-attributes-color-background-color:#ebe6d8;--replo-library-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-cfd3f928-ece3-46c2-826a-96ea0861eaa4-attributes-color-background-color:#f7f4ec" class="r-176dhhg"><div data-rid="ed22b5a9-df68-4c3b-b6dc-a6a501c2d95b" style="--replo-library-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-c7acbc5c-e816-4afb-987f-48f6886aa3f2-attributes-color-background-color:#f5f2eb;--replo-library-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-d607104b-b021-4f93-9724-53e6df016092-attributes-color-background-color:#ebe6d8" class="r-16vb6em"><button data-rid="8cda4aa7-bdfa-4483-8e08-a9b9046b7b27" class="text r-g2ritk alchemy-rte"><div data-rid="fb851491-b2ae-4d30-8590-f2d194892a2e" class="r-1xdbce5 alchemy-rte"><span style="width:100%"><p>Learn More</p></span></div></button><div data-rid="04dbd40c-999a-4496-8921-510e9c987809" class="r-s43vuc"><div data-rid="5570e771-dfaf-4cae-925b-7b05cfe8f16c" class="r-17d9us8"><div data-rid="5e46938d-d75f-487c-a949-6666c19f4cb0" class="r-1updwt9 alchemy-rte"><span style="width:100%"><p><span style="color: rgba(0, 0, 0, 0.898)">"this lip blur balm is magic"</span></p></span></div><div data-rid="7c7d8798-4528-4c44-b913-5fd1fd40284f" class="r-1okejgw alchemy-rte"><span style="width:100%"><p><span style="color: rgba(0, 0, 0, 0.898)">We know we're not the first but we intentionally didn't rush to jump on the lip balm "trend". Instead we took our time to get it right - no dryness, no stickiness, just a </span><strong><span style="color: rgba(0, 0, 0, 0.898)">hydrating, sensitive skin-friendly lip balm at an accessible $12</span></strong><span style="color: rgba(0, 0, 0, 0.898)"> that feels as good as it looks!</span></p></span></div></div><div data-rid="f516ce54-4941-4a56-959e-5789e4cb0175" class="r-l3aumt"><div data-rid="c0023f50-d527-4e34-9960-c372e6054fe2" class="r-7vkx3z"><div data-replo-component-root="compare-slider" data-replo-part="root" style="position:relative;display:flex;overflow:hidden;touch-action:none;user-select:none;min-height:0;width:100%;height:100%"><div data-replo-component-root="compare-slider" data-replo-part="clipper" style="user-select:none;will-change:clip-path, transition;width:100%;clip-path:inset(0 50% 0 0)"><div data-rid="1e917edb-c3cc-45e9-84c5-6dbb8878fc40" class="r-14afiqp"><picture data-rid="a81db042-9974-4efe-88fa-e1b777bd7d90" style="--replo-store-sectionsettings-replo-style-image-a81db042-9974-4efe-88fa-e1b777bd7d90:https://cdn.shopify.com/s/files/1/0603/2741/files/Without_be_bold_01bdc03b-3f7c-4791-82d6-279cc7562df5.png?v=1741720360" class="r-trt03z"><source srcset="https://web.archive.org/web/20250501155815im_/https://cdn.shopify.com/s/files/1/0603/2741/files/Without_be_bold_01bdc03b-3f7c-4791-82d6-279cc7562df5.png?v=1741720360" media="(max-width: 640px)"/><source srcset="https://web.archive.org/web/20250501155815im_/https://cdn.shopify.com/s/files/1/0603/2741/files/Without_be_bold_01bdc03b-3f7c-4791-82d6-279cc7562df5.png?v=1741720360" media="(min-width: 641px) and (max-width: 1024px)"/><source srcset="https://web.archive.org/web/20250501155815im_/https://cdn.shopify.com/s/files/1/0603/2741/files/Without_be_bold_01bdc03b-3f7c-4791-82d6-279cc7562df5.png?v=1741720360" media="(min-width: 1025px) and (max-width: 2400px)"/><img src="https://web.archive.org/web/20250501155815im_/https://cdn.shopify.com/s/files/1/0603/2741/files/Without_be_bold_01bdc03b-3f7c-4791-82d6-279cc7562df5.png?v=1741720360" alt="Three pairs of lips without ceramide lip blur ba