-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-0ecf2d97-fa23-412e-856d-e910e9233441-attributes-fontweight:900;--replo-library-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-0ecf2d97-fa23-412e-856d-e910e9233441-attributes-lineheight:32px;--replo-library-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-0ecf2d97-fa23-412e-856d-e910e9233441-attributes-texttransform:lowercase;--replo-library-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-bca36727-b686-44c5-a98d-8a8eb8504450-attributes-color:#282828;--replo-library-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-bca36727-b686-44c5-a98d-8a8eb8504450-attributes-fontsize:14px;--replo-library-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-bca36727-b686-44c5-a98d-8a8eb8504450-attributes-fontfamily:&quot;Libre Franklin&quot;, sans-serif;--replo-library-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-bca36727-b686-44c5-a98d-8a8eb8504450-attributes-fontweight:700;--replo-library-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-bca36727-b686-44c5-a98d-8a8eb8504450-attributes-lineheight:16.8px;--replo-library-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-5b47e2c0-aa78-4a4f-8eab-d2b33eb9bd64-attributes-color:#282828;--replo-library-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-5b47e2c0-aa78-4a4f-8eab-d2b33eb9bd64-attributes-fontsize:17px;--replo-library-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-5b47e2c0-aa78-4a4f-8eab-d2b33eb9bd64-attributes-fontfamily:&quot;Libre Franklin&quot;, sans-serif;--replo-library-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-5b47e2c0-aa78-4a4f-8eab-d2b33eb9bd64-attributes-fontweight:500;--replo-library-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-5b47e2c0-aa78-4a4f-8eab-d2b33eb9bd64-attributes-lineheight:24px"><div data-rid="3a256d92-42b2-42aa-85f2-3eec79779f58" class="r-1nvcb8h"><div data-rid="dbfa721b-e60e-4a66-8480-c09c9c089a79" style="--replo-library-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-cfd3f928-ece3-46c2-826a-96ea0861eaa4-attributes-color-background-color:#f7f4ec" class="r-1fvk6k3"><div data-rid="e37205d2-9bc7-40e1-8f94-35f72fe6f3f5" style="--replo-library-ac048764-7119-4ae1-9bd2-080e22b46f7f-styles-d607104b-b021-4f93-9724-53e6df016092-attributes-color-background-color:#ebe6d8" class="r-ugrtsg"><button data-rid="857adb99-de38-40be-a800-7cb1ae7cc5b7" class="text r-gp5ei5 alchemy-rte"><div data-rid="b4f9987c-3a07-40fb-a5a0-05527fe034bc" class="r-tfutwt alchemy-rte"><span style="width:100%"><p>Learn More</p></span></div></button><div data-rid="e2e94aad-8734-41c0-bbb6-ff297a05fb06" class="r-8n58gx"><div data-rid="b8f338bd-ae44-49b1-adfb-a0001f0ad568" class="r-1khqt52"><div data-rid="a682cce9-d9a5-4eb2-998f-36a4c629a1da" class="r-1xj5ou alchemy-rte"><span style="width:100%"><p><span style="color: rgba(0, 0, 0, 0.898)">"this lip blur balm is magic"</span></p></span></div><div data-rid="35637186-7501-4bac-bcb2-14a590a89c68" class="r-1r8nqi alchemy-rte"><span style="width:100%"><p><span style="color: rgba(0, 0, 0, 0.898)">We know we're not the first but we intentionally didn't rush to jump on the lip balm "trend". Instead we took our time to get it right - no dryness, no stickiness, just a </span><strong><span style="color: rgba(0, 0, 0, 0.898)">hydrating, sensitive skin-friendly lip balm at an accessible $12</span></strong><span style="color: rgba(0, 0, 0, 0.898)"> that feels as good as it looks!</span></p></span></div></div><div data-rid="6e0d080d-967f-4b92-ace0-2ab2e69b0f60" class="r-f3nk2i"><div data-rid="30f6112d-f8b1-4ded-979f-c16891b626b3" class="r-20vrly"><div data-rid="9d69026a-281a-44f4-a2b4-b7f93f98ff75" class="r-pr2meb"><span style="display:contents"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-plus-circle" style="fill: none;stroke: currentColor;width: var(--rsw, 100%);height: 100%" role="presentation"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg></span></div><div data-rid="79f524ff-c5d5-4d2c-b04a-66cafb8bbb85" class="r-1wgv6gi"><div data-rid="4e99f404-541b-4074-bb49-a46ad9c21ee8" class="r-1melfuj alchemy-rte"><span style="width:100%"><p>ceramides ❤️ peptides</p></span></div><div data-rid="95ac156b-33cb-4018-9e23-bda12d801560" class="r-t0qt11 alchemy-rte"><span style="width:100%"><p><span style="color: rgb(0, 0, 0)">Our cushiony formula comforts, conditions, and blurs the look of fine lines to give your lips a plump, full look</span></p></span></div></div></div><div data-rid="128ff193-f42e-495f-9cf4-9c5eaa9b7a57" class="r-sm2hj9"><div data-rid="be2645ce-9862-43be-a3ce-4d5ab073997b" class="r-10qjypz"><span style="display:contents"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-plus-circle" style="fill: none;stroke: currentColor;width: var(--rsw, 100%);height: 100%" role="presentation"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg></span></div><div data-rid="a154a05a-ccb4-444f-bbd8-679897274c2d" class="r-li6alv"><div data-rid="c71b20ef-3e3a-4fe9-b8ce-7d555df7cee7" class="r-l12ovk alchemy-rte"><span style="width:100%"><p>designed for sensitive lips</p></span></div><div data-rid="c696d3ef-b803-4177-b874-b924b0100391" class="r-16gaytz alchemy-rte"><span style="width:100%"><p><span style="color: rgb(0, 0, 0)">Specifically designed to support the lip’s thinner skin barrier </span><strong><span style="color: rgb(0, 0, 0)">without flavor &amp; fragrance, or common irritants.</span></strong></p></span></div></div></div><div data-rid="71502046-89dd-417e-ad3a-762262551c50" class="r-qv11ed"><div data-rid="f405831a-7cb9-4cf5-816a-635ee3c7b73a" class="r-1tgnkzl"><span style="display:contents"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-plus-circle" style="fill: none;stroke: currentColor;width: var(--rsw, 100%);height: 100%" role="presentation"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg></span></div><div data-rid="23b70607-146a-4b2f-a224-285c111ec911" class="r-1ahrgtd"><div data-rid="bb6523a0-0ae8-479c-9692-22156a2dd635" class="r-176v5zq alchemy-rte"><span style="width:100%"><p>take it wherever you go</p></span></div><div data-rid="d4a18db6-48d0-4c3f-8917-7c9a5e5d3e38" class="r-u1t8lp alchemy-rte"><span style="width:100%"><p><span style="color: rgb(0, 0, 0)">The built-in cap ring easily attaches to your keys, lanyard, or bag, so you’ll never lose another lip balm!</span></p></span></div></div></div></div></div><div data-rid="b8527591-5fc5-446f-b2ca-200021bc872d" class="r-11cg9q7"><div data-rid="a2e4b6cd-54f8-40ab-8fb4-63b1106c207b" class="r-uur1ds"><div data-rid="235ebcd8-8aff-4273-9f92-3e75b5ab96f1" class="r-157mkxt"><div data-replo-component-root="compare-slider" data-replo-part="root" style="position:relative;display:flex;overflow:hidden;touch-action:none;user-select:none;min-height:0;width:100%;height:100%"><div data-replo-component-root="compare-slider" data-replo-part="clipper" style="user-select:none;will-change:clip-path, transition;width:100%;clip-path:inset(0 50% 0 0)"><div data-rid="e09a61e1-a35b-47fd-aab3-0ebadbb9765a" class="r-1gkkycy"><picture data-rid="25746505-7c88-4029-aea8-86c6744fc455" style="--replo-store-sectionsettings-replo-style-image-25746505-7c88-4029-aea8-86c6744fc455:https://cdn.shopify.com/s/files/1/0603/2741/files/Without_be_bold_01bdc03b-3f7c-4791-82d6-279cc7562df5.png?v=1741720360" class="r-e45hd0"><source srcset="https://web.archive.org/web/20250501155815im_/https://cdn.shopify.com/s/files/1/0603/2741/files/Without_be_bold_01bdc03b-3f7c-4791-82d6-279cc7562df5.