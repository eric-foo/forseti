        let __showDecimal = `${__devTools?.show_decimal}` || true;
        let __roundTo = null;
        let __currentCurrency = "USD";
        let __format = "${{amount}}";

      function defaultOption(opt, def) {
          return (typeof opt == 'undefined' ? def : opt);
      }

      function formatWithDelimiters(number, precision, thousands, decimal) {
          precision = defaultOption(precision, 2);
          thousands = defaultOption(thousands, ',');
          decimal = defaultOption(decimal, '.');
          if (isNaN(number) || number == null) {
              return 0;
          }
          if (precision == 0) {
              number = (number / 100.0);
              number = Math.floor(number).toString();
          } else {
              number = (number / 100.0).toFixed(precision);
          }

          var parts = number.split('.'),
              dollars = parts[0].replace(/(\d)(?=(\d\d\d)+(?!\d))/g, '$1' + thousands),
              cents = parts[1] ? (decimal + parts[1]) : '';
          var fullAmount = dollars + cents;
          return fullAmount;
      }

      if (typeof cents == "string") {
          cents = cents.replace(".", "");
      }

      var value = "",
          placeholderRegex = /\{\{\s*(\w+)\s*\}\}/,
          formatString = __format,
          currencyDecimal = 2;

        if (__showDecimal == false) {
            currencyDecimal = 0;
        }

      switch (formatString.match(placeholderRegex)[1]) {
          case 'amount':
          case 'amount_no_decimals':
              value = formatWithDelimiters(cents, currencyDecimal);
              if (__roundTo != null && value != 0 && value.toString().indexOf(".") !== -1) {
                  value = value.substr(0, (value.toString().indexOf(".") + 1)) + __roundTo;
